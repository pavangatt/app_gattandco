# Copy this file to .env and replace values with your Supabase project settings
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SESSION_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
PORT=5000
# Comma-separated list of browser origins allowed to call the API cross-origin.
# Leave empty when the frontend is served from the same origin as the API.
CORS_ALLOWED_ORIGINS=
